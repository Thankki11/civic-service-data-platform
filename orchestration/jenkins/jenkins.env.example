# Jenkins Environment Variables & Credentials
# =====================================================================
# Đây là file MẪU. Không commit giá trị thật.
# Cần khai báo tương ứng trong Jenkins > Manage Jenkins > Credentials.
# =====================================================================

# Tên container Airflow đang chạy trên host (xem: docker ps)
STAGING_AIRFLOW_CONTAINER=data-lakehouse-skeleton-airflow-1

# Tên container Pipeline-API đang chạy trên host
STAGING_PIPELINE_API_CONTAINER=data-lakehouse-skeleton-pipeline-api-1

# Telegram (loại: Secret Text — khai báo trong Jenkins Credentials)
# ID trong Credentials: "telegram-bot-token"
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# ID trong Credentials: "telegram-chat-id"
TELEGRAM_CHAT_ID=<your_telegram_chat_id>

# Docker host (thường dùng mặc định unix socket, không cần khai báo thêm)
DOCKER_HOST=unix:///var/run/docker.sock

# GitHub Repo URL (dùng khi tạo Multibranch Pipeline job)
GITHUB_REPO_URL=https://github.com/Thankki11/civic-service-data-platform.git
